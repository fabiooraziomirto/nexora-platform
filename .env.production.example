ENVIRONMENT=production
AUTH_ENABLED=true
AUTH_DEV_BYPASS_ENABLED=false
AUTH_DEV_TOKEN=replace-only-for-non-production

KEYCLOAK_URL=https://keycloak.example.org
KEYCLOAK_REALM=nxr
KEYCLOAK_JWKS_URL=https://keycloak.example.org/realms/nxr/protocol/openid-connect/certs

AUTH_PLATFORM_ADMIN_ROLE=platform-admin
AUTH_TENANT_ADMIN_ROLE=tenant-admin
AUTH_OPERATOR_ROLE=operator
AUTH_VIEWER_ROLE=viewer

DATABASE_URL=mysql+pymysql://nxr:REPLACE_ME@mysql.nxr.svc.cluster.local:3306/nxr
KAFKA_BOOTSTRAP_SERVERS=kafka.nxr.svc.cluster.local:9092
KAFKA_REQUIRED=true
REDIS_URL=redis://redis.nxr.svc.cluster.local:6379/0
REDIS_REQUIRED=true

AGENT_CALLBACK_SECRET=REPLACE_ME
AGENT_BOOTSTRAP_TOKENS=pilot-bootstrap:REPLACE_ME:4102444800
AUDIT_LOG_PATH=/var/log/nexora/audit/events.jsonl

VITE_KEYCLOAK_URL=https://keycloak.example.org
VITE_KEYCLOAK_REALM=nxr
VITE_KEYCLOAK_CLIENT_ID=nexora-ui
