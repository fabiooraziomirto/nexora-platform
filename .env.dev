STACK4THINGS_ENV=dev
AUTH_ENABLED=false
AUTH_DEV_TOKEN=dev-token
AUTH_WRITE_ROLE=writer
KAFKA_TOPIC_PREFIX=stack4things
KAFKA_RETRY_ATTEMPTS=3
KAFKA_RETRY_DELAY_SECONDS=0.5
REQUEST_TIMEOUT_SECONDS=5
DB_CONNECT_TIMEOUT_SECONDS=5
KEYCLOAK_URL=http://localhost:18080
KEYCLOAK_REALM=stack4things
KEYCLOAK_CLIENT_ID=stack4things-ui
