# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{yaml,yml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{sh,bash}]
indent_size = 2

[*.{dockerfile,Dockerfile}]
indent_size = 4

[Makefile]
indent_style = tab

[*.{toml,ini,cfg}]
indent_size = 4

[*.{html,htm}]
indent_size = 2

[*.{css,scss}]
indent_size = 2

[*.{js,jsx,ts,tsx}]
indent_size = 2

[*.sql]
indent_size = 2

